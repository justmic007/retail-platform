{
    "info": {
        "name": "Retail Platform \u2014 Auth Service",
        "description": "Complete API collection for the Auth Service. Import this into Postman and set the `base_url` variable to test all endpoints.\n\n**Setup:**\n1. Import this collection\n2. Set `base_url` variable to `http://localhost:8080`\n3. Run Register \u2192 Login (access_token auto-saves) \u2192 test protected routes",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "base_url",
            "value": "{{auth_base_url}}",
            "description": "Resolved from the Retail Platform environment"
        },
        {
            "key": "user_id",
            "value": "",
            "description": "ID of the user to promote/demote. Set this after running Register or List users."
        }
    ],
    "item": [
        {
            "name": "Health",
            "item": [
                {
                    "name": "Health Check",
                    "request": {
                        "method": "GET",
                        "url": "{{base_url}}/health",
                        "description": "Liveness probe. Returns 200 if the service process is running. Used by Kubernetes to decide whether to restart the pod."
                    },
                    "response": [
                        {
                            "name": "200 OK",
                            "status": "OK",
                            "code": 200,
                            "body": "{\n  \"service\": \"auth\",\n  \"status\": \"ok\"\n}"
                        }
                    ]
                },
                {
                    "name": "Readiness Check",
                    "request": {
                        "method": "GET",
                        "url": "{{base_url}}/ready",
                        "description": "Readiness probe. Returns 200 if the service is ready to handle traffic (DB connected). Used by Kubernetes to decide whether to send traffic to this pod."
                    },
                    "response": [
                        {
                            "name": "200 Ready",
                            "status": "OK",
                            "code": 200,
                            "body": "{\n  \"service\": \"auth\",\n  \"status\": \"ready\"\n}"
                        }
                    ]
                }
            ]
        },
        {
            "name": "Authentication",
            "item": [
                {
                    "name": "Register",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "// Verify successful registration",
                                    "pm.test('Status is 201 Created', function() {",
                                    "    pm.response.to.have.status(201);",
                                    "});",
                                    "",
                                    "pm.test('Response has user object', function() {",
                                    "    const body = pm.response.json();",
                                    "    pm.expect(body).to.have.property('user');",
                                    "    pm.expect(body.user).to.have.property('id');",
                                    "    pm.expect(body.user).to.have.property('email');",
                                    "    pm.expect(body.user).to.have.property('role');",
                                    "    pm.expect(body.user).to.have.property('created_at');",
                                    "});",
                                    "",
                                    "pm.test('Password hash NOT in response (security check)', function() {",
                                    "    const body = pm.response.json();",
                                    "    pm.expect(body.user).to.not.have.property('password_hash');",
                                    "    pm.expect(body.user).to.not.have.property('password');",
                                    "});",
                                    "",
                                    "pm.test('Role defaults to customer', function() {",
                                    "    const body = pm.response.json();",
                                    "    pm.expect(body.user.role).to.equal('customer');",
                                    "});"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/auth/register",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"micah@example.com\",\n  \"password\": \"securepassword123\"\n}"
                        },
                        "description": "Create a new user account.\n\n**Validation rules:**\n- email: required, must be valid email format\n- password: required, minimum 8 characters\n\n**Security:** Password is hashed with bcrypt cost 12 before storage. The hash is never returned in any response."
                    },
                    "response": [
                        {
                            "name": "201 Created",
                            "status": "Created",
                            "code": 201,
                            "body": "{\n  \"user\": {\n    \"id\": \"5fc1d649-2a76-49f5-94a8-54a4bc2e7873\",\n    \"email\": \"micah@example.com\",\n    \"role\": \"customer\",\n    \"created_at\": \"2026-04-26T03:44:29.059418+01:00\"\n  }\n}"
                        },
                        {
                            "name": "400 Bad Request \u2014 validation error",
                            "status": "Bad Request",
                            "code": 400,
                            "body": "{\n  \"code\": \"VALIDATION_ERROR\",\n  \"error\": \"field 'email' failed validation: email\"\n}"
                        },
                        {
                            "name": "409 Conflict \u2014 email taken",
                            "status": "Conflict",
                            "code": 409,
                            "body": "{\n  \"code\": \"CONFLICT\",\n  \"error\": \"an account with this email already exists\"\n}"
                        }
                    ]
                },
                {
                    "name": "Login",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status is 200 OK', function() {",
                                    "    pm.response.to.have.status(200);",
                                    "});",
                                    "",
                                    "pm.test('Response has access_token, refresh_token, expires_in', function() {",
                                    "    const body = pm.response.json();",
                                    "    pm.expect(body).to.have.property('access_token');",
                                    "    pm.expect(body).to.have.property('refresh_token');",
                                    "    pm.expect(body).to.have.property('expires_in');",
                                    "    pm.expect(body.expires_in).to.equal(900);",
                                    "});",
                                    "",
                                    "// Auto-save tokens to collection variables",
                                    "// These are used automatically by protected route requests",
                                    "const body = pm.response.json();",
                                    "if (body.access_token) {",
                                    "    pm.environment.set('access_token', body.access_token);",
                                    "    console.log('access_token saved to collection variables');",
                                    "}",
                                    "if (body.refresh_token) {",
                                    "    pm.environment.set('refresh_token', body.refresh_token);",
                                    "    console.log('refresh_token saved to collection variables');",
                                    "}",
                                    "",
                                    "pm.test('expires_in is 900 seconds (15 minutes)', function() {",
                                    "    const body = pm.response.json();",
                                    "    pm.expect(body.expires_in).to.equal(900);",
                                    "});"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/auth/login",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"micah@example.com\",\n  \"password\": \"securepassword123\"\n}"
                        },
                        "description": "Authenticate a user and receive JWT tokens.\n\n**Returns:**\n- `access_token`: JWT valid for 15 minutes. Include in Authorization header for protected routes.\n- `refresh_token`: Random token valid for 7 days. Use to get a new access token when it expires.\n- `expires_in`: Seconds until access token expires (900 = 15 minutes)\n\n**Security:** Returns identical error for wrong email AND wrong password \u2014 prevents user enumeration.\n\n**Note:** The test script automatically saves tokens to collection variables."
                    },
                    "response": [
                        {
                            "name": "200 OK",
                            "status": "OK",
                            "code": 200,
                            "body": "{\n  \"access_token\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\",\n  \"refresh_token\": \"58f1dbdb8d7bd42c7d02c87562fdf8d5...\",\n  \"expires_in\": 900\n}"
                        },
                        {
                            "name": "401 Unauthorized \u2014 wrong credentials",
                            "status": "Unauthorized",
                            "code": 401,
                            "body": "{\n  \"code\": \"UNAUTHORIZED\",\n  \"error\": \"invalid email or password\"\n}"
                        }
                    ]
                },
                {
                    "name": "Refresh Token",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status is 200 OK', function() {",
                                    "    pm.response.to.have.status(200);",
                                    "});",
                                    "",
                                    "// Save new tokens \u2014 old ones are now invalid",
                                    "const body = pm.response.json();",
                                    "if (body.access_token) {",
                                    "    pm.environment.set('access_token', body.access_token);",
                                    "}",
                                    "if (body.refresh_token) {",
                                    "    pm.environment.set('refresh_token', body.refresh_token);",
                                    "}",
                                    "",
                                    "pm.test('New refresh token is different from old one (token rotation)', function() {",
                                    "    const body = pm.response.json();",
                                    "    pm.expect(body.refresh_token).to.not.be.empty;",
                                    "});"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/auth/refresh",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
                        },
                        "description": "Get a new access token using your refresh token.\n\n**Token rotation:** The old refresh token is invalidated and a new one is issued. If an attacker stole your refresh token, using it here terminates their session.\n\n**When to call:** When your access token expires (after 15 minutes / 900 seconds)."
                    },
                    "response": [
                        {
                            "name": "200 OK \u2014 new tokens issued",
                            "status": "OK",
                            "code": 200,
                            "body": "{\n  \"access_token\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\",\n  \"refresh_token\": \"new_refresh_token_here...\",\n  \"expires_in\": 900\n}"
                        },
                        {
                            "name": "401 Unauthorized \u2014 invalid token",
                            "status": "Unauthorized",
                            "code": 401,
                            "body": "{\n  \"code\": \"UNAUTHORIZED\",\n  \"error\": \"invalid or malformed token\"\n}"
                        }
                    ]
                },
                {
                    "name": "Get Current User",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status is 200 OK', function() {",
                                    "    pm.response.to.have.status(200);",
                                    "});",
                                    "",
                                    "pm.test('Returns authenticated user profile', function() {",
                                    "    const body = pm.response.json();",
                                    "    pm.expect(body).to.have.property('user');",
                                    "    pm.expect(body.user).to.have.property('id');",
                                    "    pm.expect(body.user).to.have.property('email');",
                                    "});",
                                    "",
                                    "pm.test('No password in response', function() {",
                                    "    const body = pm.response.json();",
                                    "    pm.expect(JSON.stringify(body)).to.not.include('password');",
                                    "});"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "GET",
                        "url": "{{base_url}}/auth/me",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{access_token}}",
                                "description": "JWT access token from Login response. Auto-populated if you ran Login first."
                            }
                        ],
                        "description": "Get the currently authenticated user's profile.\n\n**Requires:** Valid JWT in Authorization header.\n\n**How it works:** The JWT contains the user_id. The middleware validates the JWT and extracts the user_id. The handler fetches the full profile from the database."
                    },
                    "response": [
                        {
                            "name": "200 OK",
                            "status": "OK",
                            "code": 200,
                            "body": "{\n  \"user\": {\n    \"id\": \"5fc1d649-2a76-49f5-94a8-54a4bc2e7873\",\n    \"email\": \"micah@example.com\",\n    \"role\": \"customer\",\n    \"created_at\": \"2026-04-26T03:44:29.059418+01:00\"\n  }\n}"
                        },
                        {
                            "name": "401 Unauthorized \u2014 no token",
                            "status": "Unauthorized",
                            "code": 401,
                            "body": "{\n  \"code\": \"UNAUTHORIZED\",\n  \"error\": \"authorization header is required\"\n}"
                        },
                        {
                            "name": "401 Unauthorized \u2014 expired token",
                            "status": "Unauthorized",
                            "code": 401,
                            "body": "{\n  \"code\": \"UNAUTHORIZED\",\n  \"error\": \"invalid or expired token\"\n}"
                        }
                    ]
                },
                {
                    "name": "Logout",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status is 200 OK', function() {",
                                    "    pm.response.to.have.status(200);",
                                    "});",
                                    "",
                                    "// Clear saved tokens after logout",
                                    "pm.environment.set('access_token', '');",
                                    "pm.environment.set('refresh_token', '');",
                                    "console.log('Tokens cleared from collection variables');"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/auth/logout",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{access_token}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
                        },
                        "description": "Invalidate the refresh token.\n\n**Why send refresh_token in the body?**\nJWTs (access tokens) are stateless \u2014 they cannot be revoked server-side. Only the refresh token is stored in the database and can be deleted. Logout works by deleting the refresh_token row.\n\n**After logout:** The access token remains valid until it expires (max 15 minutes). The refresh token is immediately invalid \u2014 the user cannot get new access tokens without logging in again."
                    },
                    "response": [
                        {
                            "name": "200 OK",
                            "status": "OK",
                            "code": 200,
                            "body": "{\n  \"message\": \"logged out successfully\"\n}"
                        }
                    ]
                }
            ]
        },
        {
            "name": "Admin",
            "description": "Admin-only endpoints. Requires a JWT with role=admin.",
            "item": [
                {
                    "name": "Promote User",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status is 200 OK', function() {",
                                    "    pm.response.to.have.status(200);",
                                    "});",
                                    "",
                                    "pm.test('Response confirms role update', function() {",
                                    "    const body = pm.response.json();",
                                    "    pm.expect(body).to.have.property('message');",
                                    "    pm.expect(body.message).to.include('user role updated to');",
                                    "});"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "PATCH",
                        "url": "{{base_url}}/auth/users/{{user_id}}/role",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{access_token}}",
                                "description": "Must be an admin JWT. Login as admin@retailplatform.com first."
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"role\": \"admin\"\n}"
                        },
                        "description": "Promotes or demotes a user's role.\n\n**Valid roles:** `admin` · `customer`\n\n**Requires:** Admin JWT in Authorization header.\n\n**Note:** Role changes take effect on the user's next login — the current access token encodes the role at issue time and remains valid until it expires (15m)."
                    },
                    "response": [
                        {
                            "name": "200 OK",
                            "status": "OK",
                            "code": 200,
                            "body": "{\n  \"message\": \"user role updated to admin\"\n}"
                        },
                        {
                            "name": "400 Bad Request — invalid role",
                            "status": "Bad Request",
                            "code": 400,
                            "body": "{\n  \"error\": \"field 'role' failed validation: oneof\"\n}"
                        },
                        {
                            "name": "403 Forbidden — not an admin",
                            "status": "Forbidden",
                            "code": 403,
                            "body": "{\n  \"code\": \"FORBIDDEN\",\n  \"error\": \"insufficient permissions\"\n}"
                        }
                    ]
                },
                {
                    "name": "Promote User — invalid role (should 400)",
                    "event": [
                        {
                            "listen": "prerequest",
                            "script": {
                                "exec": [
                                    "// Log in as admin to get a fresh token — validation runs after auth,",
                                    "// so we need a valid admin token for the 400 to be reached.",
                                    "pm.sendRequest({",
                                    "    url: pm.environment.get('auth_base_url') + '/auth/login',",
                                    "    method: 'POST',",
                                    "    header: { 'Content-Type': 'application/json' },",
                                    "    body: { mode: 'raw', raw: JSON.stringify({ email: 'admin@retailplatform.com', password: 'Admin@123456' }) }",
                                    "}, function(err, res) {",
                                    "    pm.environment.set('admin_token', res.json().access_token);",
                                    "});"
                                ]
                            }
                        },
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Returns 400 for invalid role', function() {",
                                    "    pm.response.to.have.status(400);",
                                    "});",
                                    "",
                                    "pm.test('Validation error mentions role field', function() {",
                                    "    const body = pm.response.json();",
                                    "    pm.expect(body.error).to.include('role');",
                                    "});",
                                    "",
                                    "pm.environment.unset('admin_token');"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "PATCH",
                        "url": "{{base_url}}/auth/users/{{user_id}}/role",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{admin_token}}",
                                "description": "Populated by pre-request script — fresh admin token every run."
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"role\": \"superuser\"\n}"
                        },
                        "description": "Only 'admin' and 'customer' are valid roles. Anything else returns 400.\n\nThe pre-request script logs in as admin automatically so the request reaches validation (not auth)."
                    }
                },
                {
                    "name": "Promote User — customer token (should 403)",
                    "event": [
                        {
                            "listen": "prerequest",
                            "script": {
                                "exec": [
                                    "// Log in as a customer to get a fresh customer token.",
                                    "// This ensures we're testing with role=customer regardless of",
                                    "// what access_token currently holds in the environment.",
                                    "pm.sendRequest({",
                                    "    url: pm.environment.get('auth_base_url') + '/auth/login',",
                                    "    method: 'POST',",
                                    "    header: { 'Content-Type': 'application/json' },",
                                    "    body: { mode: 'raw', raw: JSON.stringify({ email: 'micah@example.com', password: 'securepassword123' }) }",
                                    "}, function(err, res) {",
                                    "    pm.environment.set('customer_token', res.json().access_token);",
                                    "});"
                                ]
                            }
                        },
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Returns 403 for non-admin token', function() {",
                                    "    pm.response.to.have.status(403);",
                                    "});",
                                    "",
                                    "pm.test('Error code is FORBIDDEN', function() {",
                                    "    const body = pm.response.json();",
                                    "    pm.expect(body.code).to.equal('FORBIDDEN');",
                                    "});",
                                    "",
                                    "pm.environment.unset('customer_token');"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "PATCH",
                        "url": "{{base_url}}/auth/users/{{user_id}}/role",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{customer_token}}",
                                "description": "Populated by pre-request script — always a fresh customer token."
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"role\": \"admin\"\n}"
                        },
                        "description": "A customer JWT cannot call this endpoint. Verifies RequireRole middleware blocks non-admins.\n\nThe pre-request script logs in as micah@example.com automatically — no need to manually set a customer token."
                    }
                },
                {
                    "name": "Promote User — no token (should 401)",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Returns 401 without token', function() {",
                                    "    pm.response.to.have.status(401);",
                                    "});",
                                    "",
                                    "pm.test('Error code is UNAUTHORIZED', function() {",
                                    "    const body = pm.response.json();",
                                    "    pm.expect(body.code).to.equal('UNAUTHORIZED');",
                                    "});"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "PATCH",
                        "url": "{{base_url}}/auth/users/{{user_id}}/role",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"role\": \"admin\"\n}"
                        },
                        "description": "No Authorization header — verifies AuthMiddleware blocks unauthenticated requests."
                    }
                }
            ]
        },
        {
            "name": "Security Tests",
            "description": "Tests that verify security behaviour \u2014 these should all return errors.",
            "item": [
                {
                    "name": "Access protected route without token",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Returns 401 without token', function() {",
                                    "    pm.response.to.have.status(401);",
                                    "});",
                                    "",
                                    "pm.test('Error message is correct', function() {",
                                    "    const body = pm.response.json();",
                                    "    pm.expect(body.code).to.equal('UNAUTHORIZED');",
                                    "});"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "GET",
                        "url": "{{base_url}}/auth/me",
                        "description": "Should return 401 \u2014 no Authorization header sent."
                    }
                },
                {
                    "name": "Login with wrong password",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Returns 401', function() {",
                                    "    pm.response.to.have.status(401);",
                                    "});",
                                    "",
                                    "pm.test('Error is generic \u2014 does not reveal if email exists', function() {",
                                    "    const body = pm.response.json();",
                                    "    pm.expect(body.error).to.equal('invalid email or password');",
                                    "    // IMPORTANT: same message as wrong email \u2014 prevents user enumeration",
                                    "});"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/auth/login",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"micah@example.com\",\n  \"password\": \"wrongpassword\"\n}"
                        },
                        "description": "Verify that wrong password returns generic error \u2014 not 'wrong password' specifically."
                    }
                },
                {
                    "name": "Login with non-existent email",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Returns 401', function() {",
                                    "    pm.response.to.have.status(401);",
                                    "});",
                                    "",
                                    "pm.test('Same error as wrong password \u2014 user enumeration prevented', function() {",
                                    "    const body = pm.response.json();",
                                    "    pm.expect(body.error).to.equal('invalid email or password');",
                                    "});"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/auth/login",
                        "header": [
                            {
                                "key": "Content-Type",
