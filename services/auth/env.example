# Auth Service Configuration
# Copy this to .env and fill in real values
# NEVER commit .env to git — only commit .env.example

APP_ENV=development
LOG_FORMAT=pretty

# Server
AUTH_PORT=8080

# Database — uses the shared Postgres container
# Format: postgres://user:password@host:port/dbname?sslmode=disable
DATABASE_URL=postgres://retail:retailsecret@localhost:5432/auth_db?sslmode=disable

# JWT — change this to a long random string in production
# Generate one: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-secret-in-production
JWT_ACCESS_TOKEN_TTL=15m     # access tokens expire in 15 minutes
JWT_REFRESH_TOKEN_TTL=7d     # refresh tokens expire in 7 days

# Rate limiting
RATE_LIMIT_REQUESTS=10       # max 10 requests
RATE_LIMIT_PERIOD=1m         # per minute per IP
