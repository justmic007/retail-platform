# Inventory Service Configuration
APP_ENV=development
LOG_FORMAT=pretty

INVENTORY_PORT=8082

DATABASE_URL=postgres://retail:retailsecret@localhost:5432/inventory_db?sslmode=disable

JWT_SECRET=change-me-to-a-long-random-secret-in-production

# Redis — for stock level caching
REDIS_URL=redis://localhost:6379/0

# How long to cache stock levels before re-checking Postgres
CACHE_TTL=5m

# Stock level below which a StockLow event is published
LOW_STOCK_THRESHOLD=10
