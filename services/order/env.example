# Order Service Configuration
APP_ENV=development
LOG_FORMAT=pretty

ORDER_PORT=8081

DATABASE_URL=postgres://retail:retailsecret@localhost:5432/order_db?sslmode=disable

# JWT secret must match Auth Service exactly — used to validate tokens
JWT_SECRET=change-me-to-a-long-random-secret-in-production

# Inventory Service URL — how Order Service calls Inventory Service
INVENTORY_SERVICE_URL=http://localhost:8082

# Worker pool — how many goroutines process orders concurrently
WORKER_POOL_SIZE=10

# How long to wait for Inventory Service to respond
INVENTORY_CLIENT_TIMEOUT=5s

AUTH_SERVICE_URL=http://localhost:8080
ORDER_SERVICE_EMAIL=order-service@internal.retailplatform.com
ORDER_SERVICE_PASSWORD=order-service-password
